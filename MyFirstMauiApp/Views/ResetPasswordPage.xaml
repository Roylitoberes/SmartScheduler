<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartScheduler.Views.ResetPasswordPage"
             Title="Reset Password"
             BackgroundColor="#F5F5F5"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid BackgroundColor="#6B32A1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Ellipse Grid.Row="0"
                     Fill="#9F7AEA"
                     HeightRequest="300"
                     WidthRequest="600"
                     HorizontalOptions="Center"
                     VerticalOptions="Start"
                     Margin="0,-150,0,0"
                     Opacity="0.5"/>

            <Ellipse Grid.Row="1"
                     Fill="#B794F4"
                     HeightRequest="400"
                     WidthRequest="600"
                     HorizontalOptions="Center"
                     VerticalOptions="End"
                     Margin="0,0,0,-200"
                     Opacity="0.4"/>
        </Grid>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="25" VerticalOptions="Center">

                <Border StrokeThickness="0"
                       Padding="20"
                       BackgroundColor="White"
                       HeightRequest="100" 
                       WidthRequest="100"
                       HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30"/>
                    </Border.StrokeShape>
                    <Image Source="smart.png" 
                           HeightRequest="60" 
                           WidthRequest="60" 
                           HorizontalOptions="Center"/>
                </Border>

                <Label Text="Reset Password"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Label Text="Enter the OTP sent to your email and create a new password"
                       FontSize="14"
                       TextColor="White"
                       Opacity="0.8"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"/>

                <Border StrokeThickness="0"
                       BackgroundColor="#F0F0F0"
                       Padding="20"
                       HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="15">

                        <Grid>
                            <Border StrokeThickness="1"
                                   Stroke="#E0E0E0"
                                   BackgroundColor="White"
                                   Padding="15,8"
                                   HeightRequest="65">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="OTP Code" 
                                           FontSize="12" 
                                           TextColor="#6B32A1" 
                                           FontAttributes="Bold"/>
                                    <Entry x:Name="OTPEntry" 
                                           Placeholder="Enter 6-digit OTP" 
                                           Keyboard="Numeric"
                                           FontSize="15" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"
                                           MaxLength="6"/>
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="🔑" 
                                   FontSize="18"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"
                                   Margin="0,0,15,0"/>
                        </Grid>

                        <Grid>
                            <Border StrokeThickness="1"
                                   Stroke="#E0E0E0"
                                   BackgroundColor="White"
                                   Padding="15,8"
                                   HeightRequest="65">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="New Password" 
                                           FontSize="12" 
                                           TextColor="#6B32A1" 
                                           FontAttributes="Bold"/>
                                    <Entry x:Name="NewPasswordEntry" 
                                           Placeholder="Enter new password" 
                                           IsPassword="True"
                                           FontSize="15" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"/>
                                </VerticalStackLayout>
                            </Border>
                            <Button x:Name="TogglePasswordButton"
                                    Text="👁️"
                                    FontSize="18"
                                    BackgroundColor="Transparent"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"
                                    Margin="0,0,10,0"
                                    Clicked="OnTogglePasswordVisibility"/>
                        </Grid>

                        <Grid>
                            <Border StrokeThickness="1"
                                   Stroke="#E0E0E0"
                                   BackgroundColor="White"
                                   Padding="15,8"
                                   HeightRequest="65">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Confirm Password" 
                                           FontSize="12" 
                                           TextColor="#6B32A1" 
                                           FontAttributes="Bold"/>
                                    <Entry x:Name="ConfirmPasswordEntry" 
                                           Placeholder="Confirm new password" 
                                           IsPassword="True"
                                           FontSize="15" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"/>
                                </VerticalStackLayout>
                            </Border>
                            <Button x:Name="ToggleConfirmPasswordButton"
                                    Text="👁️"
                                    FontSize="18"
                                    BackgroundColor="Transparent"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"
                                    Margin="0,0,10,0"
                                    Clicked="OnToggleConfirmPasswordVisibility"/>
                        </Grid>

                        <Button Text="Reset Password"
                                BackgroundColor="#6B32A1"
                                TextColor="White"
                                HeightRequest="55"
                                CornerRadius="28"
                                FontSize="16"
                                FontAttributes="Bold"
                                Clicked="OnResetPasswordClicked"/>

                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="Remember your password?" TextColor="White" Opacity="0.9"/>
                    <Label Text="Back to Login" 
                           TextColor="White" 
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <ActivityIndicator x:Name="LoadingIndicator" 
                                  IsRunning="False" 
                                  IsVisible="False" 
                                  Color="White" 
                                  HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>