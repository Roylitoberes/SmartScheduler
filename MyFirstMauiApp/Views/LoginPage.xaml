<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartScheduler.Views.LoginPage"
             Title="Login"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid BackgroundColor="#6C2BD9">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <BoxView Grid.RowSpan="2" 
                     Color="#8B5CF6" 
                     Opacity="0.3"
                     HorizontalOptions="Fill" 
                     VerticalOptions="Fill"/>

            <Ellipse Grid.Row="0"
                     Fill="#A78BFA"
                     HeightRequest="300"
                     WidthRequest="600"
                     HorizontalOptions="Center"
                     VerticalOptions="Start"
                     Margin="0,-150,0,0"
                     Opacity="0.5"/>

            <Ellipse Grid.Row="1"
                     Fill="#C084FC"
                     HeightRequest="400"
                     WidthRequest="600"
                     HorizontalOptions="Center"
                     VerticalOptions="End"
                     Margin="0,0,0,-200"
                     Opacity="0.4"/>
        </Grid>

        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="30" VerticalOptions="Center">

                <VerticalStackLayout Spacing="15" Margin="0,20,0,40">
                    <!-- Logo - LARGER SIZE -->
                    <Image Source="smart_logo.png" 
                           HeightRequest="150" 
                           WidthRequest="150" 
                           HorizontalOptions="Center"
                           Opacity="0.95">
                        <Image.Shadow>
                            <Shadow Brush="#4C1D95" 
                                   Offset="0,8" 
                                   Opacity="0.3" 
                                   Radius="20"/>
                        </Image.Shadow>
                    </Image>

                    <Label Text="Welcome Back!" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="White" 
                           HorizontalOptions="Center"
                           Margin="0,20,0,0"/>

                    <Label Text="Sign in to continue your journey" 
                           FontSize="16" 
                           TextColor="White" 
                           Opacity="0.9"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <Border StrokeThickness="0"
                       BackgroundColor="#F8F9FA"
                       Padding="20"
                       HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                               Offset="0,10" 
                               Opacity="0.1" 
                               Radius="30"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <Grid>
                            <Border StrokeThickness="1"
                                   Stroke="#E9D5FF"
                                   BackgroundColor="White"
                                   Padding="15,8"
                                   HeightRequest="65">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Email" 
                                           FontSize="12" 
                                           TextColor="#7C3AED" 
                                           FontAttributes="Bold"/>
                                    <Entry x:Name="UsernameEntry" 
                                           Placeholder="Enter your email address" 
                                           Keyboard="Email"
                                           FontSize="15" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"
                                           PlaceholderColor="#999"
                                           Margin="0,-4,0,0"/>
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="✉️" 
                                   FontSize="18"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"
                                   Margin="0,0,15,0"/>
                        </Grid>

                        <Grid>
                            <Border StrokeThickness="1"
                                   Stroke="#E9D5FF"
                                   BackgroundColor="White"
                                   Padding="15,8"
                                   HeightRequest="65">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Password" 
                                           FontSize="12" 
                                           TextColor="#7C3AED" 
                                           FontAttributes="Bold"/>
                                    <Entry x:Name="PasswordEntry" 
                                           Placeholder="Enter your password" 
                                           IsPassword="True" 
                                           FontSize="15" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"
                                           PlaceholderColor="#999"
                                           Margin="0,-4,0,0"/>
                                </VerticalStackLayout>
                            </Border>
                            <Button x:Name="TogglePasswordButton"
                                    Text="👁️"
                                    FontSize="18"
                                    BackgroundColor="Transparent"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"
                                    Margin="0,0,10,0"
                                    Clicked="OnTogglePasswordVisibility"/>
                        </Grid>

                        <HorizontalStackLayout HorizontalOptions="End" Margin="0,-5,0,0">
                            <Label Text="Forgot Password?"
                                   TextColor="#7C3AED"
                                   FontSize="12"
                                   FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <Button x:Name="LoginButton" 
                                Text="→  SIGN IN  →" 
                                FontSize="16" 
                                FontAttributes="Bold" 
                                BackgroundColor="#7C3AED" 
                                TextColor="White" 
                                HeightRequest="55" 
                                CornerRadius="28"
                                Margin="0,10,0,0"
                                Clicked="OnLoginClicked">
                            <Button.Shadow>
                                <Shadow Brush="#7C3AED" 
                                        Offset="0,8" 
                                        Opacity="0.4" 
                                        Radius="15"/>
                            </Button.Shadow>
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <Grid Margin="0,10">
                    <BoxView HeightRequest="1" 
                             BackgroundColor="White" 
                             Opacity="0.3" 
                             VerticalOptions="Center"/>
                    <Label Text="or" 
                           TextColor="White" 
                           HorizontalOptions="Center" 
                           BackgroundColor="#6C2BD9" 
                           Padding="20,0"/>
                </Grid>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,10">
                    <Label Text="New here?" TextColor="White" Opacity="0.9"/>
                    <Border StrokeThickness="0"
                           BackgroundColor="Transparent"
                           Padding="0">
                        <Label Text="Create Account" 
                               TextColor="White" 
                               FontAttributes="Bold"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </HorizontalStackLayout>

                <ActivityIndicator x:Name="LoadingIndicator" 
                                  IsRunning="False" 
                                  IsVisible="False" 
                                  Color="White" 
                                  HorizontalOptions="Center"
                                  Scale="1.5"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>