<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartScheduler.Views.RegisterPage"
             Title="Register"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid BackgroundColor="#6C2BD9">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Polygon Grid.RowSpan="2"
                     Points="0,0,300,0,150,200"
                     Fill="#8B5CF6"
                     Opacity="0.3"
                     HorizontalOptions="Start"
                     VerticalOptions="Start"/>

            <Polygon Grid.RowSpan="2"
                     Points="400,600,700,400,700,600"
                     Fill="#C084FC"
                     Opacity="0.4"
                     HorizontalOptions="End"
                     VerticalOptions="End"/>

            <Ellipse Grid.Row="0"
                     Fill="#A78BFA"
                     HeightRequest="400"
                     WidthRequest="400"
                     HorizontalOptions="End"
                     VerticalOptions="Start"
                     Margin="0,-200,0,0"
                     Opacity="0.3"/>
        </Grid>

        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,20,10,0">
                    <Border Grid.Column="0"
                           StrokeThickness="0"
                           Padding="12"
                           BackgroundColor="White"
                           HeightRequest="45" 
                           WidthRequest="45">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" 
                                   Offset="0,4" 
                                   Opacity="0.2" 
                                   Radius="10"/>
                        </Border.Shadow>
                        <Label Text="←" 
                               FontSize="21" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                    <Label Grid.Column="1" 
                           Text="Join Us Today!" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="White" 
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>

                    <BoxView Grid.Column="2" WidthRequest="45"/>
                </Grid>

                <!-- Logo - LARGER SIZE -->
                <Image Source="smart_logo.png" 
                       HeightRequest="120" 
                       WidthRequest="120" 
                       HorizontalOptions="Center"
                       Margin="0,10,0,20">
                    <Image.Shadow>
                        <Shadow Brush="#4C1D95" 
                               Offset="0,8" 
                               Opacity="0.4" 
                               Radius="20"/>
                    </Image.Shadow>
                </Image>

                <Border StrokeThickness="0"
                       BackgroundColor="#F8F9FA"
                       Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                               Offset="0,15" 
                               Opacity="0.1" 
                               Radius="30"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">

                        <!-- Username Field -->
                        <Border StrokeThickness="0"
                               BackgroundColor="White"
                               Padding="15"
                               HeightRequest="70">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#E0E0E0" 
                                       Offset="0,2" 
                                       Opacity="0.5" 
                                       Radius="5"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" 
                                       Text="👤" 
                                       FontSize="20"
                                       Margin="0,0,10,0"
                                       VerticalOptions="Center"/>
                                <Entry Grid.Column="1" 
                                       x:Name="UsernameEntry" 
                                       Placeholder="Choose username" 
                                       FontSize="16" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#333"
                                       PlaceholderColor="#999"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Email Field -->
                        <Border StrokeThickness="0"
                               BackgroundColor="White"
                               Padding="15"
                               HeightRequest="70">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#E0E0E0" 
                                       Offset="0,2" 
                                       Opacity="0.5" 
                                       Radius="5"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" 
                                       Text="📧" 
                                       FontSize="20"
                                       Margin="0,0,10,0"
                                       VerticalOptions="Center"/>
                                <Entry Grid.Column="1" 
                                       x:Name="EmailEntry" 
                                       Placeholder="Email address" 
                                       Keyboard="Email" 
                                       FontSize="16" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#333"
                                       PlaceholderColor="#999"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Password Field -->
                        <Border StrokeThickness="0"
                               BackgroundColor="White"
                               Padding="15"
                               HeightRequest="70">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#E0E0E0" 
                                       Offset="0,2" 
                                       Opacity="0.5" 
                                       Radius="5"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" 
                                       Text="🔒" 
                                       FontSize="20"
                                       Margin="0,0,10,0"
                                       VerticalOptions="Center"/>
                                <Entry Grid.Column="1" 
                                       x:Name="PasswordEntry" 
                                       Placeholder="Create password" 
                                       IsPassword="True" 
                                       FontSize="16" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#333"
                                       PlaceholderColor="#999"
                                       VerticalOptions="Center"/>
                                <Button Grid.Column="2"
                                        x:Name="TogglePasswordButton"
                                        Text="👁️"
                                        FontSize="18"
                                        BackgroundColor="Transparent"
                                        WidthRequest="40"
                                        Clicked="OnTogglePasswordVisibility"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Confirm Password Field -->
                        <Border StrokeThickness="0"
                               BackgroundColor="White"
                               Padding="15"
                               HeightRequest="70">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#E0E0E0" 
                                       Offset="0,2" 
                                       Opacity="0.5" 
                                       Radius="5"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" 
                                       Text="✓" 
                                       FontSize="20"
                                       Margin="0,0,10,0"
                                       VerticalOptions="Center"/>
                                <Entry Grid.Column="1" 
                                       x:Name="ConfirmPasswordEntry" 
                                       Placeholder="Confirm password" 
                                       IsPassword="True" 
                                       FontSize="16" 
                                       BackgroundColor="Transparent" 
                                       TextColor="#333"
                                       PlaceholderColor="#999"
                                       VerticalOptions="Center"/>
                                <Button Grid.Column="2"
                                        x:Name="ToggleConfirmPasswordButton"
                                        Text="👁️"
                                        FontSize="18"
                                        BackgroundColor="Transparent"
                                        WidthRequest="40"
                                        Clicked="OnToggleConfirmPasswordVisibility"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- OTP Field -->
                        <VerticalStackLayout x:Name="OTPContainer" IsVisible="False" Spacing="10">
                            <Border StrokeThickness="0"
                                   BackgroundColor="White"
                                   Padding="15"
                                   HeightRequest="70">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#E0E0E0" 
                                           Offset="0,2" 
                                           Opacity="0.5" 
                                           Radius="5"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0" 
                                           Text="🔑" 
                                           FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1" 
                                           x:Name="OTPEntry" 
                                           Placeholder="6-digit verification code" 
                                           Keyboard="Numeric" 
                                           FontSize="16" 
                                           BackgroundColor="Transparent" 
                                           TextColor="#333"
                                           PlaceholderColor="#999"
                                           MaxLength="6"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Send OTP Button -->
                        <Button x:Name="SendOTPButton" 
                                Text="📱  Send OTP  📱" 
                                FontSize="16" 
                                FontAttributes="Bold" 
                                BackgroundColor="#7C3AED" 
                                TextColor="White" 
                                HeightRequest="55" 
                                CornerRadius="28"
                                Margin="0,10,0,0"
                                Clicked="OnSendOTPClicked">
                            <Button.Shadow>
                                <Shadow Brush="#7C3AED" 
                                        Offset="0,5" 
                                        Opacity="0.3" 
                                        Radius="10"/>
                            </Button.Shadow>
                        </Button>

                        <!-- Register Button -->
                        <Button x:Name="RegisterButton" 
                                Text="✨  CREATE ACCOUNT  ✨" 
                                FontSize="16" 
                                FontAttributes="Bold" 
                                BackgroundColor="#D946EF" 
                                TextColor="White" 
                                HeightRequest="55" 
                                CornerRadius="28"
                                IsVisible="False"
                                Clicked="OnRegisterClicked">
                            <Button.Shadow>
                                <Shadow Brush="#D946EF" 
                                        Offset="0,5" 
                                        Opacity="0.3" 
                                        Radius="10"/>
                            </Button.Shadow>
                        </Button>
                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,10">
                    <Label Text="Member already?" TextColor="White" Opacity="0.9"/>
                    <Border StrokeThickness="0"
                           BackgroundColor="Transparent">
                        <Label Text="Sign In" 
                               TextColor="White" 
                               FontAttributes="Bold"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLoginTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </HorizontalStackLayout>

                <ActivityIndicator x:Name="LoadingIndicator" 
                                  IsRunning="False" 
                                  IsVisible="False" 
                                  Color="White" 
                                  HorizontalOptions="Center"
                                  Scale="1.5"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>