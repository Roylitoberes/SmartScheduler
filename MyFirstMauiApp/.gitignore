# Files built by VS    #
########################
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.idb
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
!Directory.Build.rsp           # but not this one
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

########################
# Profiling & coverage #
########################
*.psess                          # VS profiler
*.vsp
*.vspx
*.sap
*.coverage                       # VS code coverage
*.coveragexml
*.dotCover                       # DotCover
coverage*.json                   # Coverlet
coverage*.xml
coverage*.info
.axoCover/*                      # AxoCover
!.axoCover/settings.json

########################
# NuGet packages       #
########################
*.nupkg
*.snupkg                        # Symbol packages
**/[Pp]ackages/*
!**/[Pp]ackages/build/
#!**/[Pp]ackages/repositories.config
*.nuget.props
*.nuget.targets

########################
# Add-in specific      #
########################
_ReSharper*/                    # ReSharper
*.[Rr]e[Ss]harper
*.DotSettings.user
_TeamCity*                      # TeamCity
_NCrunch_*                      # NCrunch
.NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*
