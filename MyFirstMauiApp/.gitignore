*.GhostDoc.xml                  # GhostDoc
*.tss                           # Tabs Studio
.sass-cache/                    # Web workbench (sass)
DocProject/                     # DocGenerator
_Chutzpah*                      # Chutzpah test files
**/.mfractor/                   # MFractors

