# Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.
# Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

########################
# User-specific files #
########################
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env
*.userprefs          # MonoDevelop/Xamarin Studio
mono_crash.*         # Mono auto generated files

########################
# Build results        #
########################
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Build results on 'Bin' directories
**/[Bb]in/*
# Uncomment if you have tasks that rely on *.refresh files to move binaries
#!**/[Bb]in/*.refresh

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

########################
# Visual Studio cache  #
########################
.vs/                            # VS 2015/2017 cache/options directory
Generated\ Files/               # VS 2017 auto generated files
ipch/                           # Visual C++ cache files
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
*.[Cc]ache                     # files ending in .cache can be ignored
!?*.[Cc]ache/                  # keep track of directories ending in .cache

########################
# Test results         #
########################
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.received.*                    # Approval Tests

